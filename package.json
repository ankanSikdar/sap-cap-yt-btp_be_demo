{
  "name": "btp_be_demo",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/cds-odata-v2-adapter-proxy": "^1.9.21",
    "@sap/hana-client": "^2.29.23",
    "@sap/xssec": "^4.13.0",
    "hdb": "^2.29.4",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "@sap/hdi-deploy": "5.7.0"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "db": "hana",
      "auth": {
        "kind": "basic",
        "users": {
          "admin": {
            "password": "admin",
            "roles": [
              "authenticated-user"
            ]
          }
        }
      }
    },
    "hana": {
      "deploy-format": "hdbtable"
    }
  }
}
